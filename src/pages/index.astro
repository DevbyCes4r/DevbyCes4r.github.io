---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import { getCollection } from "astro:content";

const pageTitle =
  "La plataforma que filtra los mejores cursos gratis con salida laboral en Latinoamérica | DevbyCes4r";
const pageDescription =
  "Cursos gratis con certificación para conseguir empleo en 2026. Aprende habilidades digitales que sí están pagando.";

const allCourses = await getCollection("courses");
const recommendedCourses = allCourses
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 4);

const allPosts = await getCollection("blog");
const latestPosts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={"/images/og-image/home.webp"}
>
  <section
    class="relative h-screen flex items-center justify-center overflow-hidden pb-20 md:pb-28"
  >
    <!-- Background Stars/Dots -->
    <div class="absolute inset-0 opacity-30">
      <div
        class="absolute top-10 left-10 w-2 h-2 bg-blue-400 dark:bg-blue-300 rounded-full animate-pulse"
      >
      </div>
      <div
        class="absolute top-20 right-20 w-1 h-1 bg-purple-400 dark:bg-purple-300 rounded-full animate-pulse animation-delay-1000"
      >
      </div>
      <div
        class="absolute bottom-20 left-40 w-1.5 h-1.5 bg-pink-400 dark:bg-pink-300 rounded-full animate-pulse animation-delay-2000"
      >
      </div>
      <div
        class="absolute top-40 right-40 w-1 h-1 bg-blue-300 dark:bg-blue-200 rounded-full animate-pulse animation-delay-1500"
      >
      </div>
      <div
        class="absolute bottom-40 right-60 w-2 h-2 bg-purple-300 dark:bg-purple-200 rounded-full animate-pulse animation-delay-500"
      >
      </div>
    </div>

    <!-- Solar System Container -->
    <div class="relative w-full max-w-5xl mx-auto px-4">
      <!-- Layout centrado -->
      <div class="flex flex-col items-center justify-center">
        <!-- Center: Profile Photo + Title -->
        <div class="text-center flex-shrink-0 mb-8">
          <div class="relative group mb-4">
            <!-- Glow Effect -->
            <div
              class="absolute inset-0 bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 rounded-full blur-2xl opacity-30 group-hover:opacity-40 transition-opacity animate-pulse-slow"
            >
            </div>
            <div
              class="absolute inset-0 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 rounded-full blur-xl opacity-20 animate-spin-slow"
            >
            </div>

            <!-- Profile Image -->
            <div class="relative w-28 h-28 md:w-36 md:h-36 mx-auto">
              <img
                src="/images/author/cesar.webp"
                alt="Foto de perfil de Cesar"
                width="144"
                height="144"
                fetchpriority="high"
                loading="eager"
                decoding="async"
                class="w-full h-full rounded-full object-cover shadow-2xl border-4 border-white dark:border-slate-800 relative z-10"
              />
            </div>
          </div>

          <!-- Title Below Photo -->
          <div
            class="text-4xl md:text-5xl font-black mb-3 pb-1 bg-clip-text text-transparent bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 dark:from-blue-400 dark:via-purple-500 dark:to-pink-500"
          >
            DevbyCes4r
          </div>
          <h1
            class="text-lg md:text-xl font-bold text-slate-800 dark:text-slate-100 max-w-lg mx-auto leading-snug mb-3"
          >
            Ingeniería de Software, IA y Formación Digital
          </h1>
          <p
            class="text-sm md:text-base text-slate-600 dark:text-slate-400 max-w-md mx-auto leading-relaxed"
          >
            Explorando el universo del desarrollo para crear soluciones tecnológicas para negocios y compartiendo conocimiento a través de cursos gratuitos.
          </p>
        </div>

        <!-- Bottom Cards (3) - Only on large screens -->
        <div class="hidden lg:flex justify-center gap-12">
          <!-- Blog Card -->
          <a href="/blog" class="planet-card group animate-float-1">
            <div class="planet-icon planet-blog-icon">📝</div>
            <h3
              class="planet-title group-hover:text-blue-600 dark:group-hover:text-blue-400"
            >
              Blog
            </h3>
            <p class="planet-subtitle">Artículos</p>
          </a>

          <!-- Cursos Card -->
          <a href="/cursos" class="planet-card group animate-float-2">
            <div class="planet-icon planet-cursos-icon">🎓</div>
            <h3
              class="planet-title group-hover:text-green-600 dark:group-hover:text-green-400"
            >
              Cursos
            </h3>
            <p class="planet-subtitle">Gratuitos</p>
          </a>

          <!-- Servicios Card -->
          <a href="/servicios" class="planet-card group animate-float-3">
            <div class="planet-icon planet-tools-icon">💼</div>
            <h3
              class="planet-title group-hover:text-purple-600 dark:group-hover:text-purple-400"
            >
              Servicios
            </h3>
            <p class="planet-subtitle">Para Negocios</p>
          </a>
        </div>

        <!-- Mobile: All 3 Cards in grid -->
        <div class="lg:hidden mt-8">
          <div class="grid grid-cols-3 gap-3">
            <!-- Blog Card Mobile -->
            <a href="/blog" class="planet-card-mobile group">
              <div class="planet-icon-mobile">📝</div>
              <h3
                class="planet-title-mobile group-hover:text-blue-600 dark:group-hover:text-blue-400"
              >
                Blog
              </h3>
            </a>

            <!-- Cursos Card Mobile -->
            <a href="/cursos" class="planet-card-mobile group">
              <div class="planet-icon-mobile">🎓</div>
              <h3
                class="planet-title-mobile group-hover:text-green-600 dark:group-hover:text-green-400"
              >
                Cursos
              </h3>
            </a>

            <!-- Servicios Card Mobile -->
            <a href="/servicios" class="planet-card-mobile group">
              <div class="planet-icon-mobile">💼</div>
              <h3
                class="planet-title-mobile group-hover:text-purple-600 dark:group-hover:text-purple-400"
              >
                Servicios
              </h3>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Planet Cards - Desktop (uniform size) */
    .planet-card {
      width: 120px;
      height: 120px;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      border: 2px solid rgba(203, 213, 225, 0.3);
      border-radius: 20px;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    /* Hide desktop-only cards on mobile */
    .planet-card-desktop {
      display: none;
    }
    @media (min-width: 1024px) {
      .planet-card-desktop {
        display: flex;
      }
    }

    :global(.dark) .planet-card {
      background: rgba(30, 41, 59, 0.9);
      border-color: rgba(71, 85, 105, 0.3);
    }

    .planet-card:hover {
      transform: translateY(-8px) scale(1.05);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
    }

    /* Planet Card Elements */
    .planet-icon {
      font-size: 2rem;
      margin-bottom: 0.5rem;
      transition: transform 0.3s ease;
    }
    .group:hover .planet-icon {
      transform: scale(1.1);
    }

    .planet-title {
      font-weight: 700;
      font-size: 0.875rem;
      color: #0f172a;
      transition: color 0.3s ease;
      margin-bottom: 0.25rem;
    }
    :global(.dark) .planet-title {
      color: white;
    }

    .planet-subtitle {
      font-size: 0.75rem;
      color: #64748b;
    }
    :global(.dark) .planet-subtitle {
      color: #94a3b8;
    }

    /* Mobile Cards */
    .planet-card-mobile {
      width: 100%;
      height: 80px;
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      border: 2px solid rgba(203, 213, 225, 0.3);
      border-radius: 16px;
      padding: 0.75rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    }

    :global(.dark) .planet-card-mobile {
      background: rgba(30, 41, 59, 0.9);
      border-color: rgba(71, 85, 105, 0.3);
    }

    .planet-icon-mobile {
      font-size: 1.5rem;
      margin-bottom: 0.25rem;
    }

    .planet-title-mobile {
      font-weight: 700;
      font-size: 0.75rem;
      color: #0f172a;
      transition: color 0.3s ease;
    }
    :global(.dark) .planet-title-mobile {
      color: white;
    }

    /* Hover colors for icons */
    .planet-blog-icon {
      color: #3b82f6;
    }
    .planet-cursos-icon {
      color: #22c55e;
    }
    .planet-links-icon {
      color: #f97316;
    }
    .planet-tools-icon {
      color: #a855f7;
    }

    /* Floating Animations - Small movements in place */
    @keyframes float-1 {
      0%,
      100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-10px);
      }
    }

    @keyframes float-2 {
      0%,
      100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-15px);
      }
    }

    @keyframes float-3 {
      0%,
      100% {
        transform: translateY(0px) translateX(0px);
      }
      50% {
        transform: translateY(-12px) translateX(-5px);
      }
    }

    @keyframes float-4 {
      0%,
      100% {
        transform: translateY(0px) translateX(0px);
      }
      50% {
        transform: translateY(-12px) translateX(5px);
      }
    }

    .animate-float-1 {
      animation: float-1 3s ease-in-out infinite;
    }

    .animate-float-2 {
      animation: float-2 3.5s ease-in-out infinite;
      animation-delay: 0.5s;
    }

    .animate-float-3 {
      animation: float-3 4s ease-in-out infinite;
      animation-delay: 1s;
    }

    .animate-float-4 {
      animation: float-4 4s ease-in-out infinite;
      animation-delay: 1.5s;
    }

    /* Additional Animations */
    @keyframes pulse-slow {
      0%,
      100% {
        opacity: 0.3;
      }
      50% {
        opacity: 0.5;
      }
    }

    .animate-pulse-slow {
      animation: pulse-slow 4s ease-in-out infinite;
    }

    @keyframes spin-slow {
      from {
        transform: rotate(0deg);
      }
      to {
        transform: rotate(360deg);
      }
    }

    .animate-spin-slow {
      animation: spin-slow 10s linear infinite;
    }

    .animation-delay-500 {
      animation-delay: 0.5s;
    }
    .animation-delay-1000 {
      animation-delay: 1s;
    }
    .animation-delay-1500 {
      animation-delay: 1.5s;
    }
    .animation-delay-2000 {
      animation-delay: 2s;
    }
  </style>

  <!-- SEO Section: Cursos y Servicios -->
  <section class="py-20 border-t border-slate-200 dark:border-slate-800/50">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-20">
        <h2
          class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-6 leading-tight"
        >
          Cursos gratis con certificado para conseguir trabajo en Latinoamérica
        </h2>
        <p
          class="text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-3xl mx-auto leading-relaxed mb-4"
        >
          Descubre los mejores cursos online gratis con certificación en áreas digitales como programación, marketing e inteligencia artificial. <strong class="text-blue-600 dark:text-blue-400 font-semibold">Aprende habilidades con alta demanda y aumenta tus oportunidades laborales.</strong>
        </p>
        <p
          class="text-base text-slate-500 dark:text-slate-500 max-w-2xl mx-auto leading-relaxed"
        >
          Explora contenido actualizado, guías prácticas y recursos seleccionados para ayudarte a crecer profesionalmente. También puedes impulsar tu negocio con soluciones digitales, desarrollo web y automatizaciones con IA.
        </p>
      </div>

      <!-- Últimos Artículos -->
      <div class="mb-24">
        <div class="flex items-center justify-between mb-8">
          <h3
            class="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-3"
          >
            <span class="text-3xl">📝</span> Últimos Artículos
          </h3>
          <a
            href="/blog"
            class="text-blue-600 dark:text-blue-400 hover:underline font-medium flex items-center gap-1"
          >
            Ver todos <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path></svg
            >
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {
            latestPosts.map((post) => (
              <a
                href={`/blog/${post.slug}`}
                class="group flex flex-col bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl overflow-hidden hover:border-blue-500 dark:hover:border-blue-500 hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
              >
                <div class="aspect-video w-full overflow-hidden bg-slate-100 dark:bg-slate-900">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
                <div class="p-6 flex flex-col flex-grow">
                  <h4 class="font-bold text-xl text-slate-900 dark:text-white mb-3 line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                    {post.data.title}
                  </h4>
                  <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-3 mb-4 flex-grow">
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between text-xs text-slate-500 font-medium">
                    <span>
                      {new Date(post.data.publishDate).toLocaleDateString(
                        "es-ES",
                        { month: "short", day: "numeric", year: "numeric" },
                      )}
                    </span>
                    <span class="text-blue-600 dark:text-blue-400 group-hover:underline">
                      Leer más
                    </span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Cursos Destacados -->
      <div class="mb-24">
        <div class="flex items-center justify-between mb-8">
          <h3
            class="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-3"
          >
            <span class="text-3xl">🎓</span> Cursos Recomendados
          </h3>
          <a
            href="/cursos"
            class="text-blue-600 dark:text-blue-400 hover:underline font-medium flex items-center gap-1"
          >
            Ver todos <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path></svg
            >
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {
            recommendedCourses.map((course) => (
              <a
                href={`/cursos/${course.slug}`}
                class="group relative block p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl hover:border-blue-500 hover:shadow-xl hover:shadow-blue-500/10 transition-all duration-300"
              >
                <div class="flex items-start gap-4">
                  {/* Icon - se oculta en hover */}
                  <div class="flex-shrink-0 w-16 transition-opacity duration-300 group-hover:opacity-0">
                    <div class="h-16 w-16 bg-slate-100 dark:bg-slate-700/50 p-2 rounded-xl flex items-center justify-center text-center text-lg leading-tight overflow-hidden">
                      {course.data.icon}
                    </div>
                  </div>
                  <div
                    class="transition-transform duration-300 group-hover:-translate-x-20"
                    style="width: calc(100% - 80px);"
                  >
                    <h3 class="text-xl font-bold text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors mb-2">
                      {course.data.title}
                    </h3>
                    <p class="text-slate-600 dark:text-slate-400 text-sm line-clamp-2 mb-3">
                      {course.data.description}
                    </p>
                    {course.data.tags && course.data.tags.length > 0 && (
                      <span class="text-xs font-medium px-2 py-1 bg-blue-100 dark:bg-blue-500/10 text-blue-700 dark:text-blue-300 rounded-full border border-blue-200 dark:border-blue-500/20">
                        {course.data.tags[0]}
                      </span>
                    )}
                  </div>
                </div>

                {/* Image preview near arrow */}
                {course.data.coverImage && (
                  <div class="absolute top-16 right-4 w-0 opacity-0 group-hover:w-20 group-hover:opacity-100 overflow-hidden transition-all duration-300">
                    <img
                      src={course.data.coverImage}
                      alt={course.data.title}
                      class="w-20 h-12 object-cover rounded-lg shadow-md ring-2 ring-blue-500/50"
                      loading="lazy"
                    />
                  </div>
                )}

                <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-blue-600 dark:text-blue-400">
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"
                    />
                  </svg>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Servicios Disponibles -->
      <div
        class="bg-gradient-to-br from-slate-900 to-slate-800 dark:from-slate-800 dark:to-slate-900 rounded-[2.5rem] p-8 md:p-12 shadow-2xl relative overflow-hidden"
      >
        <div
          class="absolute top-0 right-0 w-64 h-64 bg-blue-500/20 rounded-full blur-[80px]"
        >
        </div>
        <div
          class="absolute bottom-0 left-0 w-64 h-64 bg-purple-500/20 rounded-full blur-[80px]"
        >
        </div>

        <div
          class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"
        >
          <div>
            <div
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 mb-6"
            >
              <span
                class="text-blue-400 text-sm font-bold tracking-wider uppercase"
                >Para Negocios</span
              >
            </div>
            <h3 class="text-3xl md:text-4xl font-black text-white mb-4">
              Impulsa el crecimiento de tu empresa
            </h3>
            <p class="text-lg text-slate-300 mb-8 leading-relaxed">
              Ofrecemos servicios de <strong>Marketing Digital</strong> y <strong
                >Páginas Web</strong
              > diseñados específicamente para multiplicar tus ventas de forma automática.
            </p>
            <a
              href="/servicios"
              class="inline-flex items-center gap-2 px-8 py-4 bg-yellow-400 hover:bg-yellow-500 text-slate-900 rounded-xl font-bold transition-all hover:scale-105 shadow-lg shadow-yellow-400/20"
            >
              Transformar mi negocio
            </a>
          </div>
          <div class="flex flex-col gap-4">
            <div
              class="bg-white/10 backdrop-blur-md border border-white/10 p-6 rounded-2xl hover:bg-white/20 transition-colors"
            >
              <div class="text-4xl mb-4">📣</div>
              <h4 class="text-xl font-bold text-white mb-2">
                Marketing Digital
              </h4>
              <p class="text-sm text-slate-300">
                Anuncios rentables y estrategias orientadas a resultados.
              </p>
            </div>
            <div
              class="bg-white/10 backdrop-blur-md border border-white/10 p-6 rounded-2xl hover:bg-white/20 transition-colors"
            >
              <div class="text-4xl mb-4">💻</div>
              <h4 class="text-xl font-bold text-white mb-2">Páginas Web</h4>
              <p class="text-sm text-slate-300">
                Sitios rápidos y diseñados para convertir visitas en clientes.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

<!-- Contact Section -->
<section
  id="contacto"
  class="py-24 border-t border-slate-200 dark:border-slate-800/50 relative overflow-hidden"
>
  <div class="max-w-4xl mx-auto px-4 relative z-10">
    <div class="text-center mb-12">
      <span class="inline-block text-5xl mb-6">👋</span>
      <h2
        class="text-3xl md:text-5xl font-black text-slate-900 dark:text-white mb-6"
      >
        ¿Hablamos?
      </h2>
      <p
        class="text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed"
      >
        Ya sea para una duda técnica, propuestas de trabajo o adquirir nuestros
        servicios B2B, me encantaría escucharte. Déjame un mensaje y te
        responderé muy pronto.
      </p>
    </div>

    <div class="max-w-2xl mx-auto">
      <ContactForm />
    </div>

    <div
      class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800/50 text-center"
    >
      <p
        class="text-sm text-slate-500 dark:text-slate-400 flex flex-col md:flex-row items-center justify-center gap-3"
      >
        <span>También puedes encontrarme en mis redes:</span>
        <span class="flex items-center gap-4 mt-2 md:mt-0">
          <a
            href="https://www.linkedin.com/in/devbyces4r/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-medium transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"
