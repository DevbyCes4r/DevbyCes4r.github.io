---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ScreenRecorder from "../../components/tools/ScreenRecorder.astro";
import TextToSpeech from "../../components/tools/TextToSpeech.astro";
import ImageCompressor from "../../components/tools/ImageCompressor.astro";
import QRGenerator from "../../components/tools/QRGenerator.astro";
import FlappyBird from "../../components/tools/FlappyBird.astro";
import DinoGame from "../../components/tools/DinoGame.astro";

export function getStaticPaths() {
    return [
        {
            params: { slug: "grabadora-pantalla" },
            props: {
                title: "Grabadora de Pantalla Online Gratuita",
                description:
                    "Graba tu pantalla, ventanas o pestañas del navegador sin instalar nada. Herramienta 100% gratuita y privada.",
                icon: "🎥",
                component: "ScreenRecorder",
            },
        },
        {
            params: { slug: "texto-a-voz" },
            props: {
                title: "Texto a Voz Online (TTS)",
                description:
                    "Convierte texto a voz natural usando las voces de tu sistema. Control de velocidad, tono y múltiples idiomas.",
                icon: "🗣️",
                component: "TextToSpeech",
            },
        },
        {
            params: { slug: "compresor-imagenes" },
            props: {
                title: "Compresor de Imágenes Local",
                description:
                    "Reduce el peso de tus imágenes (JPG, PNG, WebP) sin perder calidad visible. Todo se procesa en tu navegador.",
                icon: "🖼️",
                component: "ImageCompressor",
            },
        },
        {
            params: { slug: "generador-qr" },
            props: {
                title: "Generador de Códigos QR",
                description:
                    "Crea códigos QR personalizados con colores y alta resolución. Gratis y sin registro.",
                icon: "📱",
                component: "QRGenerator",
            },
        },
        {
            params: { slug: "flappy-bird" },
            props: {
                title: "Flappy Jet - Edición Espacial",
                description:
                    "Juega al clásico Flappy Bird con un jet espacial. ¡Desafía tu mejor puntuación!",
                icon: "🚀",
                component: "FlappyBird",
            },
        },
        {
            params: { slug: "dinosaurio-chrome" },
            props: {
                title: "Dinosaurio de Chrome - T-Rex Runner",
                description:
                    "El famoso juego del dinosaurio de Google Chrome cuando no hay internet. ¡Juega sin límites!",
                icon: "🦖",
                component: "DinoGame",
            },
        },
    ];
}

const { slug } = Astro.params;
const { title, description, icon, component } = Astro.props;
---

<BaseLayout
    title={`${title} | Herramientas DevbyCes4r`}
    description={description}
    image={"/images/og-image/tools.webp"}
>
    <div class="min-h-screen py-12 px-4">
        <div class="max-w-5xl mx-auto">
            <!-- Breadcrumb -->
            <a
                href="/herramientas"
                class="inline-flex items-center text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 mb-8 transition-colors"
            >
                <svg
                    class="w-5 h-5 mr-2"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Volver
            </a>

            <!-- Header -->
            <div class="text-center mb-12">
                <div class="text-6xl mb-4 animate-bounce">{icon}</div>
                <h1
                    class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4"
                >
                    {title}
                </h1>
                <p
                    class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto"
                >
                    {description}
                </p>
            </div>

            <!-- Tool Component -->
            <div class="mb-16">
                {component === "ScreenRecorder" && <ScreenRecorder />}
                {component === "TextToSpeech" && <TextToSpeech />}
                {component === "ImageCompressor" && <ImageCompressor />}
                {component === "QRGenerator" && <QRGenerator />}
                {component === "FlappyBird" && <FlappyBird />}
                {component === "DinoGame" && <DinoGame />}
            </div>

            <!-- Info Section -->
            <div class="max-w-3xl mx-auto">
                {
                    component === "ScreenRecorder" && (
                        <>
                            <div class="mb-8">
                                <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">
                                    Cómo usar
                                </h2>
                                <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
                                    Haz clic en{" "}
                                    <strong>"Grabar Pantalla"</strong>,
                                    selecciona qué compartir (pantalla, ventana
                                    o pestaña), y graba. Al terminar, descarga
                                    tu video en formato WebM.
                                </p>
                            </div>

                            <div class="flex items-start gap-3 p-5 bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-2xl border-l-4 border-green-500 mb-8">
                                <span class="text-2xl">🔒</span>
                                <p class="text-green-900 dark:text-green-100 font-medium">
                                    <strong>100% privado</strong> - Todo se
                                    procesa en tu navegador, nada se sube a
                                    servidores.
                                </p>
                            </div>

                            <p class="text-slate-600 dark:text-slate-400 italic">
                                Ideal para tutoriales, presentaciones, demos y
                                reportes de bugs.
                            </p>
                        </>
                    )
                }

                {
                    component === "TextToSpeech" && (
                        <>
                            <div class="mb-8">
                                <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">
                                    Cómo usar
                                </h2>
                                <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
                                    Escribe tu texto, selecciona idioma y voz,
                                    ajusta velocidad y tono, y reproduce.
                                </p>
                            </div>

                            <div class="flex items-start gap-3 p-5 bg-gradient-to-r from-purple-50 to-violet-50 dark:from-purple-900/20 dark:to-violet-900/20 rounded-2xl border-l-4 border-purple-500 mb-8">
                                <span class="text-2xl">🎯</span>
                                <p class="text-purple-900 dark:text-purple-100 font-medium">
                                    <strong>Múltiples idiomas</strong> • Control
                                    de velocidad y tono • 100% gratuito
                                </p>
                            </div>

                            <p class="text-slate-600 dark:text-slate-400 italic">
                                Perfecto para narraciones, audiolibros,
                                accesibilidad y aprendizaje de idiomas.
                            </p>
                        </>
                    )
                }

                {
                    component === "ImageCompressor" && (
                        <>
                            <div class="mb-8">
                                <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">
                                    Cómo usar
                                </h2>
                                <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
                                    Selecciona o arrastra imágenes (JPG, PNG,
                                    WebP), ajusta la calidad, y descarga.
                                    Soporta múltiples imágenes a la vez.
                                </p>
                            </div>

                            <div class="flex items-start gap-3 p-5 bg-gradient-to-r from-orange-50 to-amber-50 dark:from-orange-900/20 dark:to-amber-900/20 rounded-2xl border-l-4 border-orange-500 mb-8">
                                <span class="text-2xl">⚡</span>
                                <p class="text-orange-900 dark:text-orange-100 font-medium">
                                    <strong>100% privado</strong> • Rápido • Sin
                                    límites • Gratis
                                </p>
                            </div>

                            <p class="text-slate-600 dark:text-slate-400 italic">
                                Reduce hasta 90% el peso manteniendo la calidad.
                                Ideal para webs, emails y almacenamiento.
                            </p>
                        </>
                    )
                }

                {
                    component === "FlappyBird" && (
                        <>
                            <div class="mb-8">
                                <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">
                                    Cómo jugar
                                </h2>
                                <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
                                    Haz <strong>clic</strong> o presiona{" "}
                                    <strong>ESPACIO</strong> para volar. Evita
                                    los tubos, el suelo y el techo. Cada tubo
                                    que pases suma 1 punto.
                                </p>
                            </div>

                            <div class="flex items-start gap-3 p-5 bg-gradient-to-r from-red-50 to-rose-50 dark:from-red-900/20 dark:to-rose-900/20 rounded-2xl border-l-4 border-red-500 mb-8">
                                <span class="text-2xl">🎮</span>
                                <p class="text-red-900 dark:text-red-100 font-medium">
                                    <strong>Consejo:</strong> Clics cortos,
                                    ritmo constante, mantén la calma
                                </p>
                            </div>

                            <p class="text-slate-600 dark:text-slate-400 italic">
                                Tu mejor puntuación se guarda automáticamente.
                                ¡Desafía tus reflejos!
                            </p>
                        </>
                    )
                }

                {
                    component === "DinoGame" && (
                        <>
                            <div class="mb-8">
                                <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">
                                    Cómo jugar
                                </h2>
                                <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
                                    Haz clic en el juego. Presiona{" "}
                                    <strong>ESPACIO</strong> o{" "}
                                    <strong>↑</strong> para saltar. Presiona{" "}
                                    <strong>↓</strong> para agacharte. Evita
                                    cactus y pterodáctilos.
                                </p>
                            </div>

                            <div class="flex items-start gap-3 p-5 bg-gradient-to-r from-slate-50 to-gray-50 dark:from-slate-800/50 dark:to-gray-800/50 rounded-2xl border-l-4 border-slate-500 mb-8">
                                <span class="text-2xl">🦖</span>
                                <p class="text-slate-900 dark:text-slate-100 font-medium">
                                    <strong>Dato curioso:</strong> Creado por
                                    Google en 2014. Se vuelve más rápido cada
                                    100 puntos.
                                </p>
                            </div>

                            <p class="text-slate-600 dark:text-slate-400 italic">
                                El clásico juego de Chrome sin necesidad de
                                desconectarte. Diseño minimalista, desafío
                                creciente.
                            </p>
                        </>
                    )
                }

                {
                    component === "QRGenerator" && (
                        <>
                            <div class="mb-8">
                                <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">
                                    Cómo usar
                                </h2>
                                <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
                                    Ingresa tu URL o texto, personaliza colores
                                    y tamaño, y descarga. El QR se genera
                                    instantáneamente mientras escribes.
                                </p>
                            </div>

                            <div class="flex items-start gap-3 p-5 bg-gradient-to-r from-cyan-50 to-blue-50 dark:from-cyan-900/20 dark:to-blue-900/20 rounded-2xl border-l-4 border-cyan-500 mb-8">
                                <span class="text-2xl">📱</span>
                                <p class="text-cyan-900 dark:text-cyan-100 font-medium">
                                    <strong>Usos:</strong> Enlaces, WiFi,
                                    tarjetas de presentación, menús, pagos
                                </p>
                            </div>

                            <p class="text-slate-600 dark:text-slate-400 italic">
                                Descarga en alta resolución PNG. Escaneable con
                                cualquier smartphone.
                            </p>
                        </>
                    )
                }
            </div>
        </div>
    </div>
</BaseLayout>
