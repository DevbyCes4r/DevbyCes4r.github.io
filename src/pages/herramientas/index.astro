---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "Herramientas para Desarrolladores y AI | DevbyCes4r";
const pageDescription =
  "Colección curada de herramientas esenciales para desarrollo web e inteligencia artificial.";

const aiTools = [
  {
    name: "ChatGPT",
    description:
      "Asistente de IA conversacional de OpenAI para programación, escritura y más.",
    icon: "🤖",
    url: "https://chat.openai.com",
    category: "IA Conversacional",
  },
  {
    name: "Claude",
    description:
      "IA de Anthropic especializada en análisis profundo y programación.",
    icon: "🧠",
    url: "https://claude.ai",
    category: "IA Conversacional",
  },
  {
    name: "GitHub Copilot",
    description:
      "Asistente de código impulsado por IA que sugiere código en tiempo real.",
    icon: "✨",
    url: "https://github.com/features/copilot",
    category: "Programación IA",
  },
  {
    name: "Midjourney",
    description: "Generador de imágenes con IA de alta calidad.",
    icon: "🎨",
    url: "https://www.midjourney.com",
    category: "Generación de Imágenes",
  },
  {
    name: "Perplexity",
    description: "Motor de búsqueda potenciado por IA con respuestas precisas.",
    icon: "🔍",
    url: "https://www.perplexity.ai",
    category: "Búsqueda IA",
  },
  {
    name: "V0 by Vercel",
    description: "Genera componentes de UI con IA usando prompts de texto.",
    icon: "⚡",
    url: "https://v0.dev",
    category: "Desarrollo UI",
  },
];

const devTools = [
  {
    name: "Visual Studio Code",
    description: "Editor de código potente y extensible de Microsoft.",
    icon: "💻",
    url: "https://code.visualstudio.com",
    category: "Editor de Código",
  },
  {
    name: "Figma",
    description:
      "Herramienta colaborativa de diseño de interfaces y prototipos.",
    icon: "🎨",
    url: "https://www.figma.com",
    category: "Diseño UI/UX",
  },
  {
    name: "GitHub",
    description:
      "Plataforma de desarrollo colaborativo con control de versiones.",
    icon: "🐙",
    url: "https://github.com",
    category: "Control de Versiones",
  },
  {
    name: "Vercel",
    description: "Plataforma de deployment para aplicaciones web modernas.",
    icon: "▲",
    url: "https://vercel.com",
    category: "Deployment",
  },
  {
    name: "Postman",
    description: "Plataforma para desarrollo y testing de APIs.",
    icon: "📮",
    url: "https://www.postman.com",
    category: "Testing API",
  },
  {
    name: "Chrome DevTools",
    description: "Herramientas de desarrollo integradas en Google Chrome.",
    icon: "🔧",
    url: "https://developer.chrome.com/docs/devtools",
    category: "Debugging",
  },
  {
    name: "Stack Overflow",
    description: "Comunidad de preguntas y respuestas para programadores.",
    icon: "📚",
    url: "https://stackoverflow.com",
    category: "Comunidad",
  },
  {
    name: "Can I Use",
    description:
      "Verifica compatibilidad de características web en navegadores.",
    icon: "🌐",
    url: "https://caniuse.com",
    category: "Compatibilidad",
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={"/images/og-image/tools.webp"}
>
  <div class="min-h-screen py-10 px-4 flex justify-center">
    <div class="w-full max-w-5xl">
      <!-- Header -->
      <div class="text-center mb-16">
        <div class="text-6xl mb-4 animate-bounce">🛠️</div>
        <h1
          class="text-4xl md:text-5xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 dark:from-blue-400 dark:via-purple-500 dark:to-pink-500 mb-6"
        >
          Recursos Esenciales
        </h1>
        <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
          Las mejores herramientas para desarrollo web e inteligencia
          artificial.
        </p>
      </div>

      <!-- Games Section -->
      <div class="mb-20" id="juegos">
        <div class="flex items-center gap-4 mb-8">
          <h2
            class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white border-l-4 border-red-500 pl-4"
          >
            <a href="#juegos" class="hover:text-red-500 transition-colors">
              Juegos y Entretenimiento
            </a>
          </h2>
          <div class="h-px bg-slate-200 dark:bg-slate-800 flex-grow"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <a
            href="/herramientas/flappy-bird"
            class="group relative block p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl hover:-translate-y-1 hover:border-red-500 hover:shadow-xl hover:shadow-red-500/10 transition-all duration-300"
          >
            <div class="flex items-start gap-4">
              <div
                class="text-4xl bg-red-50 dark:bg-red-500/10 p-3 rounded-xl group-hover:scale-110 transition-transform duration-300"
              >
                🚀
              </div>
              <div>
                <h3
                  class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-red-600 dark:group-hover:text-red-400 transition-colors"
                >
                  Flappy Jet - Edición Espacial
                </h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm mb-3">
                  Juega al clásico Flappy Bird con un jet espacial. ¡Desafía tu
                  mejor puntuación!
                </p>
                <span
                  class="text-xs font-medium px-2 py-1 bg-red-100 dark:bg-red-500/10 text-red-700 dark:text-red-300 rounded-full border border-red-200 dark:border-red-500/20"
                >
                  Juego Web
                </span>
              </div>
            </div>

            <div
              class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-red-600 dark:text-red-400"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </a>

          <a
            href="/herramientas/dinosaurio-chrome"
            class="group relative block p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl hover:-translate-y-1 hover:border-slate-500 hover:shadow-xl hover:shadow-slate-500/10 transition-all duration-300"
          >
            <div class="flex items-start gap-4">
              <div
                class="text-4xl bg-slate-50 dark:bg-slate-700/50 p-3 rounded-xl group-hover:scale-110 transition-transform duration-300"
              >
                🦖
              </div>
              <div>
                <h3
                  class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-slate-600 dark:group-hover:text-slate-400 transition-colors"
                >
                  Dinosaurio de Chrome
                </h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm mb-3">
                  El clásico T-Rex Runner de Google Chrome. ¡Sin necesidad de
                  desconectarte!
                </p>
                <span
                  class="text-xs font-medium px-2 py-1 bg-slate-100 dark:bg-slate-700/50 text-slate-700 dark:text-slate-300 rounded-full border border-slate-200 dark:border-slate-600"
                >
                  Juego Web
                </span>
              </div>
            </div>

            <div
              class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-slate-600 dark:text-slate-400"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </a>
        </div>
      </div>

      <!-- Online Tools Section (New) -->
      <div class="mb-20" id="herramientas-online">
        <div class="flex items-center gap-4 mb-8">
          <h2
            class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white border-l-4 border-green-500 pl-4"
          >
            <a
              href="#herramientas-online"
              class="hover:text-green-500 transition-colors"
            >
              Utilidades Online Gratuitas
            </a>
          </h2>
          <div class="h-px bg-slate-200 dark:bg-slate-800 flex-grow"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <a
            href="/herramientas/grabadora-pantalla"
            class="group relative block p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl hover:-translate-y-1 hover:border-green-500 hover:shadow-xl hover:shadow-green-500/10 transition-all duration-300"
          >
            <div class="flex items-start gap-4">
              <div
                class="text-4xl bg-green-50 dark:bg-green-500/10 p-3 rounded-xl group-hover:scale-110 transition-transform duration-300"
              >
                🎥
              </div>
              <div>
                <h3
                  class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors"
                >
                  Grabadora de Pantalla
                </h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm mb-3">
                  Graba tu pantalla, ventanas o pestañas sin instalar nada. 100%
                  privado y gratuito.
                </p>
                <span
                  class="text-xs font-medium px-2 py-1 bg-green-100 dark:bg-green-500/10 text-green-700 dark:text-green-300 rounded-full border border-green-200 dark:border-green-500/20"
                >
                  Herramienta Web
                </span>
              </div>
            </div>

            <div
              class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-green-600 dark:text-green-400"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </a>

          <a
            href="/herramientas/texto-a-voz"
            class="group relative block p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl hover:-translate-y-1 hover:border-purple-500 hover:shadow-xl hover:shadow-purple-500/10 transition-all duration-300"
          >
            <div class="flex items-start gap-4">
              <div
                class="text-4xl bg-purple-50 dark:bg-purple-500/10 p-3 rounded-xl group-hover:scale-110 transition-transform duration-300"
              >
                🗣️
              </div>
              <div>
                <h3
                  class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors"
                >
                  Texto a Voz (TTS)
                </h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm mb-3">
                  Convierte texto a audio natural. Ideal para crear locuciones o
                  accesibilidad.
                </p>
                <span
                  class="text-xs font-medium px-2 py-1 bg-purple-100 dark:bg-purple-500/10 text-purple-700 dark:text-purple-300 rounded-full border border-purple-200 dark:border-purple-500/20"
                >
                  Herramienta Web
                </span>
              </div>
            </div>

            <div
              class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-purple-600 dark:text-purple-400"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </a>

          <a
            href="/herramientas/compresor-imagenes"
            class="group relative block p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl hover:-translate-y-1 hover:border-orange-500 hover:shadow-xl hover:shadow-orange-500/10 transition-all duration-300"
          >
            <div class="flex items-start gap-4">
              <div
                class="text-4xl bg-orange-50 dark:bg-orange-500/10 p-3 rounded-xl group-hover:scale-110 transition-transform duration-300"
              >
                🖼️
              </div>
              <div>
                <h3
                  class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-orange-600 dark:group-hover:text-orange-400 transition-colors"
                >
                  Compresor de Imágenes
                </h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm mb-3">
                  Reduce el peso de tus imágenes sin subir nada a internet.
                  Rápido y privado.
                </p>
                <span
                  class="text-xs font-medium px-2 py-1 bg-orange-100 dark:bg-orange-500/10 text-orange-700 dark:text-orange-300 rounded-full border border-orange-200 dark:border-orange-500/20"
                >
                  Herramienta Web
                </span>
              </div>
            </div>

            <div
              class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-orange-600 dark:text-orange-400"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </a>

          <a
            href="/herramientas/generador-qr"
            class="group relative block p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl hover:-translate-y-1 hover:border-cyan-500 hover:shadow-xl hover:shadow-cyan-500/10 transition-all duration-300"
          >
            <div class="flex items-start gap-4">
              <div
                class="text-4xl bg-cyan-50 dark:bg-cyan-500/10 p-3 rounded-xl group-hover:scale-110 transition-transform duration-300"
              >
                📱
              </div>
              <div>
                <h3
                  class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-cyan-600 dark:group-hover:text-cyan-400 transition-colors"
                >
                  Generador de QR
                </h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm mb-3">
                  Crea códigos QR personalizados con colores. Ideal para
                  compartir enlaces o wifi.
                </p>
                <span
                  class="text-xs font-medium px-2 py-1 bg-cyan-100 dark:bg-cyan-500/10 text-cyan-700 dark:text-cyan-300 rounded-full border border-cyan-200 dark:border-cyan-500/20"
                >
                  Herramienta Web
                </span>
              </div>
            </div>

            <div
              class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-cyan-600 dark:text-cyan-400"
            >
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </div>
          </a>
        </div>
      </div>

      <!-- AI Tools Section -->
      <div class="mb-20" id="herramientas-ia">
        <div class="flex items-center gap-4 mb-8">
          <h2
            class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white border-l-4 border-purple-600 dark:border-purple-500 pl-4"
          >
            <a
              href="#herramientas-ia"
              class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors"
            >
              Inteligencia Artificial
            </a>
          </h2>
          <div class="h-px bg-slate-200 dark:bg-slate-800 flex-grow"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {
            aiTools.map((tool) => (
              <a
                href={tool.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative block p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl hover:-translate-y-1 hover:border-purple-500 hover:shadow-xl hover:shadow-purple-500/10 transition-all duration-300"
              >
                <div class="flex items-start gap-4">
                  <div class="text-4xl bg-slate-100 dark:bg-slate-700/50 p-3 rounded-xl group-hover:scale-110 transition-transform duration-300">
                    {tool.icon}
                  </div>
                  <div>
                    <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">
                      {tool.name}
                    </h3>
                    <p class="text-slate-600 dark:text-slate-400 text-sm mb-3">
                      {tool.description}
                    </p>
                    <span class="text-xs font-medium px-2 py-1 bg-purple-100 dark:bg-purple-500/10 text-purple-700 dark:text-purple-300 rounded-full border border-purple-200 dark:border-purple-500/20">
                      {tool.category}
                    </span>
                  </div>
                </div>

                <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-purple-600 dark:text-purple-400">
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                    />
                  </svg>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Dev Tools Section -->
      <div class="mb-20" id="herramientas-desarrollo">
        <div class="flex items-center gap-4 mb-8">
          <h2
            class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white border-l-4 border-blue-600 dark:border-blue-500 pl-4"
          >
            <a
              href="#herramientas-desarrollo"
              class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              Desarrollo Web
            </a>
          </h2>
          <div class="h-px bg-slate-200 dark:bg-slate-800 flex-grow"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {
            devTools.map((tool) => (
              <a
                href={tool.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative block p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl hover:-translate-y-1 hover:border-purple-500 hover:shadow-xl hover:shadow-purple-500/10 transition-all duration-300"
              >
                <div class="flex items-start gap-4">
                  <div class="text-4xl bg-slate-100 dark:bg-slate-700/50 p-3 rounded-xl group-hover:scale-110 transition-transform duration-300">
                    {tool.icon}
                  </div>
                  <div>
                    <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors">
                      {tool.name}
                    </h3>
                    <p class="text-slate-600 dark:text-slate-400 text-sm mb-3">
                      {tool.description}
                    </p>
                    <span class="text-xs font-medium px-2 py-1 bg-purple-100 dark:bg-purple-500/10 text-purple-700 dark:text-purple-300 rounded-full border border-purple-200 dark:border-purple-500/20">
                      {tool.category}
                    </span>
                  </div>
                </div>

                <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-purple-600 dark:text-purple-400">
                  <svg
                    class="w-6 h-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                    />
                  </svg>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <!-- CTA Section -->
      <div
        class="mt-16 p-8 bg-gradient-to-br from-blue-600 to-purple-600 rounded-2xl text-center text-white shadow-lg"
      >
        <h2 class="text-2xl font-bold mb-4">📚 ¿Buscas aprender?</h2>
        <p class="mb-6 text-blue-50">
          Explora nuestra colección de cursos gratuitos
        </p>
        <a
          href="/cursos"
          class="inline-block px-8 py-4 bg-white text-blue-600 rounded-xl font-bold text-lg hover:scale-105 hover:shadow-xl transition-all duration-300"
        >
          Ver Cursos Gratuitos 🎓
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
