---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactForm from "../../components/ContactForm.astro";

const pageTitle = "Servicios de Tecnología y Marketing Digital | DevbyCes4r";
const pageDescription =
  "Servicios premium de desarrollo tecnológico a medida y marketing digital con inteligencia artificial para escalar tu negocio.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image={"/images/og-image/servicios.webp"}
  fullWidth={true}
>
  <!-- Hero Section -->
  <section
    class="relative min-h-[95vh] flex items-center justify-center overflow-hidden py-32 px-4"
  >
    <!-- Background Gradients (Light/Dark aware) -->
    <div class="absolute inset-0 bg-white dark:bg-slate-950 -z-30"></div>
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-50/50 via-white to-white dark:from-slate-900 dark:via-slate-950 dark:to-slate-950 -z-20"
    >
    </div>

    <!-- Animated Orbs -->
    <div
      class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-400/20 dark:bg-blue-600/20 rounded-full blur-[128px] animate-blob -z-10"
    >
    </div>
    <div
      class="absolute top-1/3 right-1/4 w-96 h-96 bg-purple-400/20 dark:bg-purple-600/20 rounded-full blur-[128px] animate-blob animation-delay-2000 -z-10"
    >
    </div>
    <div
      class="absolute -bottom-32 left-1/2 w-96 h-96 bg-pink-400/20 dark:bg-pink-600/20 rounded-full blur-[128px] animate-blob animation-delay-4000 -z-10"
    >
    </div>

    <!-- Grid Pattern -->
    <div
      class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.03)_1px,transparent_1px)] dark:bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_80%_80%_at_50%_50%,#000_70%,transparent_100%)] -z-10"
    >
    </div>

    <div
      class="relative z-10 w-full max-w-6xl mx-auto text-center flex flex-col items-center"
    >
      <!-- Status Badge -->
      <div
        class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-white/40 dark:bg-slate-900/40 border border-slate-200/60 dark:border-slate-700/60 backdrop-blur-xl mb-10 shadow-lg animate-fade-in-up"
      >
        <span class="relative flex h-3 w-3">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"
          ></span>
        </span>
        <span
          class="text-sm font-bold text-slate-800 dark:text-slate-200 tracking-wide"
          >Agendando proyectos</span
        >
      </div>

      <!-- Headline -->
      <h1
        class="text-5xl sm:text-6xl md:text-8xl font-black mb-8 tracking-tighter text-slate-900 dark:text-white leading-[1.1] animate-fade-in-up animation-delay-100 max-w-5xl"
      >
        Moderniza tu negocio.<br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 dark:from-blue-400 dark:via-purple-400 dark:to-pink-400"
        >
          Multiplica tus ventas.
        </span>
      </h1>

      <!-- Subheadline -->
      <p
        class="text-xl md:text-2xl text-slate-600 dark:text-slate-400 max-w-3xl mx-auto mb-14 leading-relaxed font-medium animate-fade-in-up animation-delay-200"
      >
        Construimos ecosistemas digitales y sistemas de marketing impulsados por
        Inteligencia Artificial para que tu empresa opere y venda en piloto
        automático.
      </p>

      <!-- CTA Buttons -->
      <div
        class="flex flex-col sm:flex-row gap-6 w-full sm:w-auto px-4 sm:px-0 animate-fade-in-up animation-delay-300"
      >
        <a
          href="#contacto"
          class="w-full sm:w-auto px-10 py-5 bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-2xl font-bold text-lg hover:scale-105 hover:shadow-2xl hover:shadow-slate-900/20 dark:hover:shadow-white/20 transition-all duration-300 group flex items-center justify-center gap-2"
        >
          Quiero transformar mi negocio
          <svg
            class="w-5 h-5 group-hover:translate-x-1 transition-transform"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
          >
        </a>
        <a
          href="#servicios"
          class="w-full sm:w-auto px-10 py-5 bg-white/50 dark:bg-slate-900/50 backdrop-blur-md border border-slate-200 dark:border-slate-800 text-slate-900 dark:text-white rounded-2xl font-bold text-lg hover:bg-white dark:hover:bg-slate-800 transition-all duration-300 flex items-center justify-center"
        >
          Ver Servicios
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div
      class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50"
    >
      <svg
        class="w-6 h-6 text-slate-600 dark:text-slate-400"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg
      >
    </div>
  </section>

  <!-- The Two Pillars -->
  <section id="servicios" class="py-32 bg-slate-50 dark:bg-slate-900 relative">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="text-center mb-20">
        <span
          class="text-blue-600 dark:text-blue-400 font-bold tracking-widest uppercase text-sm mb-4 block"
          >Nuestros Motores</span
        >
        <h2
          class="text-4xl md:text-6xl font-black text-slate-900 dark:text-white"
        >
          Dos áreas, un solo objetivo:<br />Escalar tu negocio.
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <!-- Marketing IA Card -->
        <div
          class="group relative rounded-[2.5rem] bg-white dark:bg-slate-950 p-10 md:p-14 shadow-xl shadow-slate-200/50 dark:shadow-none border border-slate-200 dark:border-slate-800 overflow-hidden transition-all duration-500 hover:shadow-2xl hover:-translate-y-2"
        >
          <div
            class="absolute top-0 right-0 w-[500px] h-[500px] bg-gradient-to-bl from-purple-500/10 to-pink-500/5 rounded-bl-full -z-10 group-hover:scale-110 transition-transform duration-700"
          >
          </div>

          <div
            class="w-20 h-20 bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 rounded-3xl flex items-center justify-center text-4xl mb-8 group-hover:scale-110 transition-transform duration-500"
          >
            🤖
          </div>

          <h3 class="text-3xl font-black text-slate-900 dark:text-white mb-6">
            Marketing Digital
          </h3>
          <p
            class="text-lg text-slate-600 dark:text-slate-400 mb-10 leading-relaxed"
          >
            Sistemas automatizados de atracción y conversión. Usamos
            Inteligencia Artificial para crear campañas que resuenan y venden
            24/7.
          </p>

          <ul class="space-y-6">
            <li class="flex items-start gap-4">
              <div
                class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-purple-100 dark:bg-purple-900/50 flex items-center justify-center"
              >
                <svg
                  class="w-4 h-4 text-purple-600 dark:text-purple-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path></svg>
              </div>
              <span class="text-slate-700 dark:text-slate-300 font-medium"
                >Creación de piezas publicitarias de alto impacto (Diseño +
                Copywriting).</span
              >
            </li>
            <li class="flex items-start gap-4">
              <div
                class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-purple-100 dark:bg-purple-900/50 flex items-center justify-center"
              >
                <svg
                  class="w-4 h-4 text-purple-600 dark:text-purple-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path></svg>
              </div>
              <span class="text-slate-700 dark:text-slate-300 font-medium"
                >Estrategias basadas en datos predictivos y comportamiento de
                usuario.</span
              >
            </li>
            <li class="flex items-start gap-4">
              <div
                class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-purple-100 dark:bg-purple-900/50 flex items-center justify-center"
              >
                <svg
                  class="w-4 h-4 text-purple-600 dark:text-purple-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path></svg>
              </div>
              <span class="text-slate-700 dark:text-slate-300 font-medium"
                >Automatizaciones para generación de contenido y bots de
                atención.</span
              >
            </li>
          </ul>
        </div>

        <!-- Desarrollo Tech Card -->
        <div
          class="group relative rounded-[2.5rem] bg-white dark:bg-slate-950 p-10 md:p-14 shadow-xl shadow-slate-200/50 dark:shadow-none border border-slate-200 dark:border-slate-800 overflow-hidden transition-all duration-500 hover:shadow-2xl hover:-translate-y-2"
        >
          <div
            class="absolute top-0 right-0 w-[500px] h-[500px] bg-gradient-to-bl from-blue-500/10 to-cyan-500/5 rounded-bl-full -z-10 group-hover:scale-110 transition-transform duration-700"
          >
          </div>

          <div
            class="w-20 h-20 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-3xl flex items-center justify-center text-4xl mb-8 group-hover:scale-110 transition-transform duration-500"
          >
            💻
          </div>

          <h3 class="text-3xl font-black text-slate-900 dark:text-white mb-6">
            Desarrollo a la Medida
          </h3>
          <p
            class="text-lg text-slate-600 dark:text-slate-400 mb-10 leading-relaxed"
          >
            Tu negocio necesita una base sólida. Desarrollamos software
            ultra-rápido, aplicaciones y páginas que no solo se ven bien, sino
            que convierten.
          </p>

          <ul class="space-y-6">
            <li class="flex items-start gap-4">
              <div
                class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center"
              >
                <svg
                  class="w-4 h-4 text-blue-600 dark:text-blue-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path></svg>
              </div>
              <span class="text-slate-700 dark:text-slate-300 font-medium"
                >Sitios web y Landing Pages de alta conversión y velocidad
                extrema.</span
              >
            </li>
            <li class="flex items-start gap-4">
              <div
                class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center"
              >
                <svg
                  class="w-4 h-4 text-blue-600 dark:text-blue-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path></svg>
              </div>
              <span class="text-slate-700 dark:text-slate-300 font-medium"
                >Aplicaciones Móviles Nativas (iOS & Android) para fidelizar
                clientes.</span
              >
            </li>
            <li class="flex items-start gap-4">
              <div
                class="mt-1 flex-shrink-0 w-6 h-6 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center"
              >
                <svg
                  class="w-4 h-4 text-blue-600 dark:text-blue-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path></svg>
              </div>
              <span class="text-slate-700 dark:text-slate-300 font-medium"
                >Sistemas ERP/CRM SaaS y Dashboards operativos personalizados.</span
              >
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Parallax Section -->
  <section
    class="py-32 relative text-white overflow-hidden bg-slate-900 dark:bg-black"
  >
    <div class="absolute inset-0 z-0 opacity-40 mix-blend-color-dodge">
      <div
        class="absolute top-0 right-0 w-full h-full bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-900/40 via-transparent to-transparent"
      >
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <div class="text-center mb-20">
        <h2 class="text-4xl md:text-5xl font-black mb-6">
          ¿Por qué invertir en tecnología?
        </h2>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto">
          La tecnología no es un gasto, es tu empleado más eficiente y
          escalable.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Benefit 1 -->
        <div
          class="bg-slate-800/40 backdrop-blur-xl border border-slate-700/50 rounded-3xl p-8 hover:bg-slate-800/60 transition-colors"
        >
          <div
            class="w-14 h-14 bg-green-500/20 text-green-400 rounded-2xl flex items-center justify-center text-2xl mb-6"
          >
            📈
          </div>
          <h4 class="text-2xl font-bold mb-3 text-white">Ventas 24/7</h4>
          <p class="text-slate-400 font-medium leading-relaxed">
            Embúdos de venta automáticos que operan incluso mientras duermes.
          </p>
        </div>
        <!-- Benefit 2 -->
        <div
          class="bg-slate-800/40 backdrop-blur-xl border border-slate-700/50 rounded-3xl p-8 hover:bg-slate-800/60 transition-colors"
        >
          <div
            class="w-14 h-14 bg-blue-500/20 text-blue-400 rounded-2xl flex items-center justify-center text-2xl mb-6"
          >
            ⏱️
          </div>
          <h4 class="text-2xl font-bold mb-3 text-white">Recupera Tiempo</h4>
          <p class="text-slate-400 font-medium leading-relaxed">
            Automatiza tareas manuales. Dirige tu empresa, no la operes.
          </p>
        </div>
        <!-- Benefit 3 -->
        <div
          class="bg-slate-800/40 backdrop-blur-xl border border-slate-700/50 rounded-3xl p-8 hover:bg-slate-800/60 transition-colors"
        >
          <div
            class="w-14 h-14 bg-purple-500/20 text-purple-400 rounded-2xl flex items-center justify-center text-2xl mb-6"
          >
            🛡️
          </div>
          <h4 class="text-2xl font-bold mb-3 text-white">Control Total</h4>
          <p class="text-slate-400 font-medium leading-relaxed">
            Dashboards centralizados para ver la salud de tu negocio en tiempo
            real.
          </p>
        </div>
        <!-- Benefit 4 -->
        <div
          class="bg-slate-800/40 backdrop-blur-xl border border-slate-700/50 rounded-3xl p-8 hover:bg-slate-800/60 transition-colors"
        >
          <div
            class="w-14 h-14 bg-pink-500/20 text-pink-400 rounded-2xl flex items-center justify-center text-2xl mb-6"
          >
            🚀
          </div>
          <h4 class="text-2xl font-bold mb-3 text-white">Escalabilidad</h4>
          <p class="text-slate-400 font-medium leading-relaxed">
            Crece tus ingresos sin necesidad de multiplicar tu infraestructura
            física.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industrias Grid -->
  <section class="py-32 bg-white dark:bg-slate-950">
    <div class="max-w-7xl mx-auto px-4">
      <div
        class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6"
      >
        <div class="max-w-2xl">
          <h2
            class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-6"
          >
            Soluciones por Sector
          </h2>
          <p class="text-xl text-slate-600 dark:text-slate-400">
            Adaptamos la tecnología a tu nicho de mercado para obtener
            resultados inmediatos.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          [
            {
              icon: "🍔",
              title: "Restaurantes & Gastronomía",
              desc: "Sistemas de pedidos propios (sin comisiones), menús QR interactivos y programas de lealtad.",
            },
            {
              icon: "✂️",
              title: "Salones de Belleza & Spas",
              desc: "Agendamiento automático 24/7, recordatorios por WhatsApp y venta de productos online.",
            },
            {
              icon: "🚗",
              title: "Automotriz & Talleres",
              desc: "Software de reservas de turnos, historiales de servicio de vehículos y facturación.",
            },
            {
              icon: "🩺",
              title: "Salud & Consultorios",
              desc: "Gestión de pacientes, telemedicina, recetas digitales e historial clínico seguro en la nube.",
            },
            {
              icon: "🛍️",
              title: "Retail & E-commerce",
              desc: "Tiendas online de alta conversión, sincronización de inventario físico-digital y remarketing IA.",
            },
            {
              icon: "🏢",
              title: "B2B & Startups",
              desc: "Sistemas internos ERP/CRM y plataformas SaaS completas escalables para miles de usuarios.",
            },
          ].map((item) => (
            <div class="group p-8 rounded-3xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:bg-white dark:hover:bg-slate-800 hover:border-blue-500/50 dark:hover:border-blue-500/50 hover:shadow-xl transition-all duration-300">
              <div class="text-4xl mb-6 transform group-hover:scale-110 transition-transform origin-left">
                {item.icon}
              </div>
              <h4 class="text-xl font-bold text-slate-900 dark:text-white mb-3">
                {item.title}
              </h4>
              <p class="text-slate-600 dark:text-slate-400 font-medium leading-relaxed">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA / Contacto -->
  <section
    id="contacto"
    class="py-32 bg-slate-900 dark:bg-black relative overflow-hidden"
  >
    <!-- Background Patterns -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-0 right-0 w-full h-full bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-blue-900/40 via-transparent to-transparent"></div>
      <div class="absolute bottom-0 left-0 w-full h-full bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-purple-900/40 via-transparent to-transparent"></div>
      <!-- Grid -->
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_70%,transparent_100%)]"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <div class="bg-slate-800/40 backdrop-blur-2xl border border-slate-700/50 rounded-[3rem] p-8 md:p-16 lg:p-20 shadow-2xl overflow-hidden relative">
        <!-- Glow inside the card -->
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-blue-500/20 rounded-full blur-[100px] pointer-events-none"></div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center relative z-10">
          
          <!-- Left Content -->
          <div class="text-left">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 mb-8">
              <span class="text-blue-400 text-sm font-bold tracking-wider uppercase">Inicia tu transformación</span>
            </div>
            
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 leading-tight">
              Diseñemos tu<br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">
                próximo éxito.
              </span>
            </h2>
            
            <p class="text-xl text-slate-400 font-medium mb-10 leading-relaxed max-w-lg">
              Agenda una sesión estratégica gratuita. Analizaremos tu situación actual y te mostraremos un plan de acción claro para escalar tus ventas.
            </p>

            <div class="space-y-6">
              <div class="flex items-center gap-4 text-slate-300">
                <div class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center border border-slate-700 flex-shrink-0">🎯</div>
                <div>
                  <h4 class="font-bold text-white text-lg">Objetivos Claros</h4>
                  <p class="text-sm text-slate-400">Definiremos tus metas de negocio.</p>
                </div>
              </div>
              <div class="flex items-center gap-4 text-slate-300">
                <div class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center border border-slate-700 flex-shrink-0">⚡</div>
                <div>
                  <h4 class="font-bold text-white text-lg">Estrategia Rápida</h4>
                  <p class="text-sm text-slate-400">Soluciones para implementar de inmediato.</p>
                </div>
              </div>
              <div class="flex items-center gap-4 text-slate-300">
                <div class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center border border-slate-700 flex-shrink-0">🤝</div>
                <div>
                  <h4 class="font-bold text-white text-lg">Cero Compromiso</h4>
                  <p class="text-sm text-slate-400">Totalmente transparente y sin ataduras.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Form -->
          <div class="relative">
            <div class="absolute -inset-1 bg-gradient-to-r from-blue-500 to-purple-600 rounded-[2.5rem] blur opacity-20 group-hover:opacity-40 transition duration-1000"></div>
