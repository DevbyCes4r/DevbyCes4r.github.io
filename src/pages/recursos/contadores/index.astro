---
import { getEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const resource = await getEntry("recursos", "contadores");
if (!resource) return Astro.redirect("/recursos");
const { data, body } = resource;
const { Content } = await resource.render();
const hasContent = body && body.trim().length > 0;

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: data.title,
    description: data.description,
    numberOfItems: data.links?.length,
    itemListElement: data.links?.map((link, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: link.title,
        url: link.url,
    })),
};
---

<BaseLayout
    title="Pack GRATIS para Contadores | DevbyCes4r"
    description={data.description}
    image={"/images/og-image/link.webp"}
>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <div class="min-h-screen px-4 py-8 md:py-12 flex justify-center">
        <div class="w-full max-w-5xl">
            <!-- Hero para contadores (LinkedIn style) -->
            <div
                class="relative rounded-3xl overflow-hidden mb-12 bg-emerald-900 border-4 border-emerald-500/20 shadow-2xl"
            >
                <div class="absolute inset-0 bg-gradient-to-br from-emerald-800 via-teal-900 to-emerald-950"></div>
                <!-- Decoración -->
                <div class="absolute top-0 right-0 p-8 opacity-10">
                    <svg class="w-64 h-64 text-emerald-400" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.31-8.86c-1.77-.45-2.34-.94-2.34-1.67 0-.84.79-1.43 2.1-1.43 1.38 0 1.9.66 1.94 1.64h1.71c-.05-1.34-.87-2.57-2.49-2.97V5H10.9v1.69c-1.51.32-2.72 1.3-2.72 2.81 0 1.79 1.49 2.69 3.66 3.21 1.95.46 2.34 1.15 2.34 1.87 0 .53-.39 1.64-2.25 1.64-1.74 0-2.1-.96-2.17-1.92H8.01c.09 1.96 1.42 2.87 2.89 3.19V19h2.33v-1.64c1.83-.31 2.96-1.36 2.96-3.03-.01-2.25-1.72-2.97-3.88-3.49z"/>
                    </svg>
                </div>
                
                <div class="relative z-10 p-8 md:p-12">
                    <div
                        class="inline-flex items-center gap-2 bg-emerald-500 text-white text-xs font-bold px-4 py-1.5 rounded-full mb-6 uppercase tracking-wider"
                    >
                        🚨 Solo por tiempo limitado
                    </div>
                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 text-white leading-tight"
                    >
                        🎁 PACK GRATIS<br />
                        <span class="text-emerald-400">PARA CONTADORES</span>
                    </h1>
                    
                    <p class="text-lg md:text-xl text-emerald-100 max-w-2xl mb-8 leading-relaxed">
                        Si eres contador o te estás preparando para serlo y quieres actualizarte, 
                        automatizar procesos con IA y acceder a mejores oportunidades laborales…
                        Esto es para ti 👇🏻
                    </p>

                    <!-- Beneficios -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-emerald-50 font-medium">
                        <a href="#cursos-principales" class="flex items-center gap-3 bg-emerald-800/50 p-3 rounded-xl border border-emerald-700/50 hover:bg-emerald-700/50 hover:border-emerald-500 hover:scale-105 transition-all text-emerald-50">
                            <span class="text-2xl">🎓</span> 13 Cursos GRATIS + Certificado
                        </a>
                        <a href="#prompts-ia" class="flex items-center gap-3 bg-emerald-800/50 p-3 rounded-xl border border-emerald-700/50 hover:bg-emerald-700/50 hover:border-emerald-500 hover:scale-105 transition-all text-emerald-50">
                            <span class="text-2xl">⚡</span> Prompts IA para ser 3X rápido
                        </a>
                        <a href="#cursos-ia" class="flex items-center gap-3 bg-emerald-800/50 p-3 rounded-xl border border-emerald-700/50 hover:bg-emerald-700/50 hover:border-emerald-500 hover:scale-105 transition-all text-emerald-50">
                            <span class="text-2xl">🤖</span> 10 Cursos IA Contable
                        </a>
                        <a href="#vacantes" class="flex items-center gap-3 bg-emerald-800/50 p-3 rounded-xl border border-emerald-700/50 hover:bg-emerald-700/50 hover:border-emerald-500 hover:scale-105 transition-all text-emerald-50">
                            <span class="text-2xl">💼</span> Vacantes y Plantillas CV
                        </a>
                    </div>
                </div>
            </div>

            <!-- Cursos Principales (del frontmatter) -->
            <div id="cursos-principales" class="mb-14 scroll-mt-24">
                <div class="flex items-center gap-3 mb-6">
                    <span class="text-3xl">🎓</span>
                    <h2 class="text-2xl md:text-3xl font-bold text-slate-900 dark:text-white">
                        13 Cursos GRATIS + Certificado
                    </h2>
                </div>
                <p class="text-slate-600 dark:text-slate-400 mb-6">
                    Módulos y formaciones para fortalecer tu perfil como Auxiliar, Contador, Analista Financiero o Tesorero.
                </p>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    {
                        data.links?.map((link, i) => (
                            <a
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="group flex items-center justify-between p-4 bg-white dark:bg-slate-800 border-2 border-slate-100 dark:border-slate-700 rounded-2xl hover:border-emerald-500 hover:shadow-lg hover:shadow-emerald-500/10 transition-all"
                            >
                                <div class="flex items-center gap-3">
                                    <div class="text-2xl bg-emerald-50 dark:bg-emerald-900/30 p-2 rounded-xl group-hover:scale-110 transition-transform">
                                        {link.icon || "📚"}
                                    </div>
                                    <h3 class="font-bold text-slate-800 dark:text-slate-200 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors text-sm">
                                        {link.title}
                                    </h3>
                                </div>
                                <svg class="w-4 h-4 text-slate-400 group-hover:text-emerald-500 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                </svg>
                            </a>
                        ))
                    }
                </div>
            </div>

            <!-- Divisor -->
            <div class="h-px bg-gradient-to-r from-transparent via-emerald-200 dark:via-emerald-800 to-transparent my-12"></div>

            <!-- Contenido Principal (Prompts, IA Cursos, CVs) -->
            {
                hasContent && (
                    <div class="prose prose-lg prose-slate dark:prose-invert max-w-none 
                        prose-headings:font-bold prose-headings:text-slate-900 dark:prose-headings:text-white 
                        prose-h2:text-2xl prose-h2:flex prose-h2:items-center prose-h2:gap-3 
                        prose-h3:text-xl prose-h3:text-emerald-700 dark:prose-h3:text-emerald-400
                        prose-a:text-emerald-600 dark:prose-a:text-emerald-400 prose-a:no-underline hover:prose-a:underline
                        prose-strong:text-slate-900 dark:prose-strong:text-emerald-100
                        prose-ul:list-disc prose-li:marker:text-emerald-500
                        ai-content-wrapper"
                    >
                        <Content />
                    </div>
                )
            }

            {
                hasContent && (
                    <script>
                        document.querySelectorAll(".ai-content-wrapper a").forEach((a) => {
                            const href = a.getAttribute("href");
                            if (href?.startsWith("#")) return;
                            a.setAttribute("target", "_blank");
                            a.setAttribute("rel", "noopener noreferrer");
                            // Styling for links inside markdown to look like buttons when appropriate
                            if(href?.includes('indeed.com') || href?.includes('canva.com')) {
                                a.className = "inline-flex items-center gap-1 font-semibold text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300 transition-colors";
                            }
                        });

                        // Agregar botones de copiar a los bloques de código (prompts)
                        document.querySelectorAll(".ai-content-wrapper pre").forEach((pre) => {
                            const button = document.createElement("button");
                            button.innerHTML = "Copiar Prompt";
                            button.className = "absolute top-3 right-3 bg-emerald-600/20 hover:bg-emerald-600/40 text-emerald-400 hover:text-emerald-300 text-xs font-bold py-1 px-3 rounded transition-colors";
                            
                            button.addEventListener("click", () => {
                                const code = pre.querySelector("code");
                                if(code) {
                                    navigator.clipboard.writeText(code.innerText);
                                    button.innerHTML = "¡Copiado!";
                                    button.classList.add("bg-emerald-500", "text-white");
                                    button.classList.remove("text-emerald-400", "bg-emerald-600/20");
                                    
                                    setTimeout(() => {
                                        button.innerHTML = "Copiar Prompt";
                                        button.classList.remove("bg-emerald-500", "text-white");
                                        button.classList.add("text-emerald-400", "bg-emerald-600/20");
                                    }, 2000);
                                }
                            });
                            
                            pre.appendChild(button);
                        });
                    </script>
                )
            }

            <!-- CTA Final -->
            <div
                class="mt-16 text-center bg-gradient-to-r from-emerald-600 to-teal-700 rounded-3xl p-10 text-white shadow-xl"
            >
                <h3 class="text-3xl font-extrabold mb-4">
                    Comienza a transformar tu carrera hoy
                </h3>
                <p class="text-emerald-100 mb-8 max-w-2xl mx-auto text-lg hover:">
                    Guarda esta página en tus favoritos o compártela con colegas contadores para que también aprovechen este pack gratuito.
                </p>
                <div class="flex flex-col sm:flex-row justify-center gap-4">
                    <button
                        onclick="navigator.clipboard.writeText(window.location.href); alert('¡Enlace copiado al portapapeles!');"
                        class="inline-flex justify-center items-center gap-2 bg-emerald-800 hover:bg-emerald-900 text-white font-bold px-8 py-4 rounded-xl transition-all"
                    >
                        📋 Copiar enlace del Pack
                    </button>
                    <a
                        href="/recursos"
                        class="inline-flex justify-center items-center gap-2 bg-white text-emerald-800 font-bold px-8 py-4 rounded-xl hover:bg-emerald-50 transition-all shadow-lg"
                    >
                        Ver más recursos tech
                    </a>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>

<style is:global>
    /* Estilos específicos para el markdown de esta página */
    .ai-content-wrapper h3 {
        margin-top: 2.5rem;
        margin-bottom: 1rem;
    }
    .ai-content-wrapper p {
        margin-top: 0.5rem;
        margin-bottom: 1rem;
    }
    
    /* Estilizar la lista de Prompts como código */
    .ai-content-wrapper p:has(+ ol), .ai-content-wrapper p:has(+ ul) {
        margin-bottom: 0.5rem;
    }

    /* Estilos para los bloques de código (Prompts) */
    .ai-content-wrapper pre {
        background-color: #0f172a; /* slate-900 */
        border: 1px solid rgba(16, 185, 129, 0.3); /* verde esmeralda suave */
        border-radius: 0.75rem;
        padding: 1.5rem;
        margin-top: 1rem;
        margin-bottom: 2rem;
        overflow-x: auto;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        position: relative;
    }
    .ai-content-wrapper pre code {
        color: #e2e8f0; /* slate-200 */
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 0.9rem;
        line-height: 1.6;
        white-space: pre-wrap; /* Permite que el texto baje de línea */
    }
</style>

<script>
    import { waitForGoatCounter } from "../../../utils/analytics";

    waitForGoatCounter(() => {
        const gc = window.goatcounter;
        if (!gc?.count) return;

        // 1. Trackear clics en los 13 cursos del frontmatter (grid #cursos-principales)
        document.querySelectorAll("#cursos-principales a[href]").forEach((a) => {
            a.addEventListener("click", () => {
                const h3 = a.querySelector("h3");
                const label = (h3 as HTMLElement ?? a as HTMLElement).innerText.trim();
                gc.count({
                    path: `${label}`,
                    title: "Clic en Curso - 13 Cursos Gratis Contadores",
                    event: true,
                });
            });
        });

        // 2. Trackear clics en los 10 cursos de IA (solo los 2 ul inmediatos a #cursos-ia)
        const cursosIaSelectors = "#cursos-ia + #ia-para-contabilidad + ul a[href], #cursos-ia + #ia-para-contabilidad + ul + #ia-para-finanzas + ul a[href]";
        document.querySelectorAll<HTMLAnchorElement>(cursosIaSelectors).forEach((a) => {
            a.addEventListener("click", () => {
                gc.count({
                    path: `${a.innerText.trim()}`,
                    title: "Clic en Curso - 10 Cursos IA Contable",
                    event: true,
                });
            });
        });

        // 3. Trackear cualquier clic en vacantes (sección #vacantes del markdown) — un solo registro
        document.querySelectorAll("#vacantes + p + ul a[href]").forEach((a) => {
            a.addEventListener("click", () => {
                gc.count({
                    path: "click-vacante-contadores",
                    title: "Clic en Vacante - Recursos Contadores",
                    event: true,
                });
            });
        });

        // 4. Trackear clic en el link de Plantillas de Canva (sección #plantillas-cv del markdown)
        document.querySelectorAll("#plantillas-cv + p + p>a[href]").forEach((a) => {
            a.addEventListener("click", () => {
                gc.count({
                    path: "click-plantillas-cv-contadores",
                    title: "Clic en Plantillas CV Canva - Recursos Contadores",
                    event: true,
                });
            });
        });
    });
</script>
